{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clipboarder",
  "version": "0.1.0",
  "identifier": "com.clipboarder.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "clipboarder",
        "width": 880,
        "height": 520,
        "minWidth": 720,
        "minHeight": 420,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": true,
        "shadow": true,
        "focus": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPCACHE/**", "$APPLOCALDATA/**", "$TEMP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "shortDescription": "A faster, more beautiful clipboard manager",
    "longDescription": "clipboarder is a clipboard manager for macOS — searchable history with smart classification for text, links, code, colors, emails, files, PDFs, music, video, and images. Press ⌘⇧V from anywhere.",
    "copyright": "© 2026 clipboarder",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "category": "public.app-category.productivity"
  }
}
